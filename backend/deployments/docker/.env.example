# Copy this file to .env and fill in production values.
# Sensitive values should be provided via your secret manager in production.

# Database
DB_PASSWORD=change_me_db_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT
JWT_SECRET=change_me_jwt_secret

# Grafana
GRAFANA_PASSWORD=change_me_grafana_password

# Optional: other API keys used by the app
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# FCM_SERVER_KEY=your_fcm_server_key


# Notes:
# - Never commit the actual .env with secrets to version control.
# - In production use Docker secrets, a secrets manager, or environment injection from your orchestrator.
