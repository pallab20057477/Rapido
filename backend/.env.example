# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
GIN_MODE=release

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=rapido
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_TIMEZONE=Asia/Kolkata
DB_LOG_LEVEL=release

# Redis Configuration
# REDIS_ADDR can be "localhost:6379" or just "localhost" (port from REDIS_PORT)
REDIS_ADDR=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=rapido_jwt_secret_key_development_2024
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# Twilio Configuration (for SMS/OTP) - Leave empty to use mock OTP
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMS country code prefix (default: +91 for India)
SMS_COUNTRY_CODE=+91

# FCM Configuration (for Push Notifications) - Leave empty to skip
FCM_SERVER_KEY=

# Google OAuth Configuration - Leave empty to skip
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External CRM / Hotel Integration - Leave disabled until hotel CRM is available
EXTERNAL_CRM_ENABLED=false
EXTERNAL_CRM_BASE_URL=
EXTERNAL_CRM_TOKEN=
EXTERNAL_CRM_WEBHOOK_SECRET=
EXTERNAL_CRM_WEBHOOK_API_KEY=
EXTERNAL_CRM_WEBHOOK_ALLOWED_IPS=
EXTERNAL_CRM_TIMEOUT_SECONDS=5

# Application Settings
DEFAULT_CURRENCY=INR
PLATFORM_COMMISSION_PERCENT=20
DRIVER_SEARCH_RADIUS_KM=5
RIDE_REQUEST_TIMEOUT_SECONDS=45
OTP_EXPIRY_MINUTES=5

# Razorpay (for payments) - Test keys
RAZORPAY_KEY_ID=rzp_test_SampleKeyId
RAZORPAY_KEY_SECRET=SampleSecretKey

# AWS S3 (for file uploads - optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=rapido-uploads

# CORS
CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173

# Base URL
PUBLIC_BASE_URL=http://localhost:8080

# Upload path
UPLOAD_BASE_PATH=./uploads

# Admin Credentials (for initial admin user creation)
# Set these to automatically create an admin user on startup
# Login with: POST /api/v1/auth/login
# Body: {"identifier": "admin@rapido.com", "password": "admin123"}
ADMIN_EMAIL=admin@rrrapido.com
ADMIN_PASSWORD=admin33123
ADMIN_NAME=System Administrator
ADMIN_PHONE=99889999999

# Development only — OTP bypass (leave empty or remove in production)
# When APP_ENV=development and this is set, this code is accepted as a valid OTP
DEV_TEST_OTP=123456

# Invoice GST percentage (default: 18)
INVOICE_GST_PERCENT=18

# Cancellation policy
CANCELLATION_FREE_WINDOW_SEC=120
CANCELLATION_FLAT_FEE=20
CANCELLATION_AFTER_ASSIGNED_PERCENT=0.50
CANCELLATION_AFTER_ARRIVED_PERCENT=0.75

# Driver matching wave configuration
MATCHING_WAVE1_RADIUS_KM=3
MATCHING_WAVE1_TIMEOUT_SEC=5
MATCHING_WAVE1_LIMIT=3
MATCHING_WAVE2_RADIUS_KM=5
MATCHING_WAVE2_TIMEOUT_SEC=5
MATCHING_WAVE2_LIMIT=5
MATCHING_WAVE3_RADIUS_KM=8
MATCHING_WAVE3_TIMEOUT_SEC=10
MATCHING_WAVE3_LIMIT=10
MATCHING_FALLBACK_RADIUS_KM=12
MATCHING_FALLBACK_TIMEOUT_SEC=15
MATCHING_FALLBACK_LIMIT=10

# Redis geo-sharding (optional — defaults to primary REDIS_ADDR:REDIS_PORT)
# REDIS_SHARD_SOUTH=localhost:6379
# REDIS_SHARD_WEST=localhost:6379
# REDIS_SHARD_NORTH=localhost:6379
# REDIS_SHARD_EAST=localhost:6379
# REDIS_SHARD_CENTRAL=localhost:6379
